{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FloristReviewIntelligenceRecord",
  "type": "object",
  "required": ["id", "brand", "market", "source", "source_url", "text", "collected_at", "status"],
  "properties": {
    "id": {"type": "string"},
    "brand": {"type": "string"},
    "brand_alias": {"type": ["string", "null"]},
    "market": {"type": "string"},
    "source": {"type": "string"},
    "source_url": {"type": "string"},
    "review_url": {"type": ["string", "null"]},
    "reviewer": {"type": ["string", "null"]},
    "rating": {"type": ["number", "null"]},
    "review_date": {"type": ["string", "null"]},
    "collected_at": {"type": "string"},
    "title": {"type": ["string", "null"]},
    "text": {"type": "string"},
    "language": {"type": "string"},
    "sentiment": {"type": "string", "enum": ["positive", "mixed", "negative", "unknown"]},
    "themes": {"type": "array", "items": {"type": "string"}},
    "complaints": {"type": "array", "items": {"type": "string"}},
    "delight_drivers": {"type": "array", "items": {"type": "string"}},
    "purchase_drivers": {"type": "array", "items": {"type": "string"}},
    "objections": {"type": "array", "items": {"type": "string"}},
    "emotion_words": {"type": "array", "items": {"type": "string"}},
    "customer_phrases": {"type": "array", "items": {"type": "string"}},
    "job_to_be_done": {"type": "string"},
    "operational_issue": {"type": "string"},
    "competitor_opportunity": {"type": ["string", "null"]},
    "confidence": {"type": "number"},
    "status": {"type": "string"}
  },
  "additionalProperties": true
}
