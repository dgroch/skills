# Brand Asset Manifesting configuration template
# Copy this to your private runtime env file. Never commit filled secrets.

# Google Drive/shared-drive folder to crawl
DRIVE_FOLDER_ID=

# Notion destination. Use an existing database OR a parent page where the script can create one.
NOTION_BRAND_ASSET_DATABASE_ID=
NOTION_BRAND_ASSET_PARENT_PAGE_ID=

# Gemini access path. Prefer OpenRouter if available; direct Google Gemini is also supported.
GEMINI_PROVIDER=openrouter
GEMINI_MODEL=google/gemini-3-flash-preview
# Set OPENROUTER_API_KEY in your private env file.
# Or use direct Gemini:
# GEMINI_PROVIDER=google
# GEMINI_MODEL=gemini-2.5-flash
# Set GEMINI_API_KEY or GOOGLE_API_KEY in your private env file.

# Notion
# Set NOTION_API_KEY in your private env file.

# Batch settings
MANIFEST_LIMIT=25
MANIFEST_RECURSIVE=true
MANIFEST_RENAME_FILES=true
ASSET_TAXONOMY_VERSION=v0-discovery
MANIFEST_WORKDIR=/opt/data/brand-asset-manifests/notion-drive-assets

# Brand CDN/public preview settings.
# If both are set, generated thumbnails are copied under BRAND_CDN_UPLOAD_DIR/asset-manifest/YYYY/MM/
# and exposed as BRAND_CDN_BASE_URL/asset-manifest/YYYY/MM/<thumbnail>.jpg.
BRAND_CDN_BASE_URL=
BRAND_CDN_UPLOAD_DIR=
