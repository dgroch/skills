{
  "version": "4.0",
  "description": "Fig & Bloom email template library. Agent selects templates and injects content tokens. No HTML is generated \u2014 only token values.",
  "assembly": {
    "shell_preview": "shell/shell-preview.html",
    "shell_production": "shell/shell-production.html",
    "shell_tokens": {
      "CAMPAIGN_NAME": "Email subject line or campaign name",
      "BODY_BG": "Body background colour (default: #2c2825)",
      "FONT_CDN_LINK": "Production only: <link> tag for hosted font CSS. Omit if not configured.",
      "COMPONENTS": "Assembled component HTML \u2014 injected between <!-- COMPONENTS_START --> and <!-- COMPONENTS_END -->"
    },
    "method": "1. Select components. 2. Fill all {{TOKEN}} values. 3. Read each template file. 4. Replace tokens. 5. Concatenate. 6. Inject into shell between markers. 7. Validate no {{}} remain.",
    "html_only_components": [
      "opt-out",
      "section-headline",
      "delivery-cutoffs",
      "footer",
      "divider-line",
      "divider-whitespace"
    ],
    "slice_components": [
      "header",
      "all hero variants",
      "all product cards",
      "body-copy",
      "testimonial",
      "upsell-noir",
      "trust-bar",
      "divider-illo-*"
    ],
    "note": "body-copy is sliced (not HTML) because it contains a position:absolute illustration that does not render in email clients as inline HTML. Slicing captures it correctly."
  },
  "ordering_rules": {
    "required": [
      "header",
      "hero (one)",
      "body-copy",
      "section-headline",
      "products (1-5)",
      "trust-bar",
      "footer"
    ],
    "optional_positions": {
      "opt-out": "Immediately after hero \u2014 position 3. Required for: Mothers Day, Fathers Day, Valentines Day, pregnancy/baby, memorial.",
      "divider": "Max one non-line divider per email. Between body-copy and products.",
      "testimonial": "After products, before promo-code.",
      "promo-code": "After testimonial, before upsell.",
      "upsell-noir": "Near bottom \u2014 closing beat. After promo-code.",
      "delivery-cutoffs": "After upsell, before trust-bar."
    }
  },
