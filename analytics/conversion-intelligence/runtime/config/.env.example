# Conversion Intelligence Programme — secrets & config
# Copy to config/.env and fill in. NEVER commit the real .env (see .gitignore).

# ---- GA4 (Behavioural funnel — read-only) -------------------------------
# Numeric GA4 property id (Admin > Property Settings), NOT the "G-" measurement id.
GA4_PROPERTY_ID=000000000
# Either a path to the service-account JSON, or the raw JSON string.
# The service account needs the "Viewer" role on the GA4 property.
GA4_SERVICE_ACCOUNT_JSON=/home/user/secrets/ga4-service-account.json

# ---- Shopify (Outcome truth) --------------------------------------------
SHOPIFY_STORE=lechoixflowers.myshopify.com
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional; defaults to a known-good Admin API version.
SHOPIFY_API_VERSION=2025-01

# ---- Mida.so (Causal / experiments) -------------------------------------
# Reporting API (primary path). Region base: https://api-us.mida.so or https://api-eu.mida.so
MIDA_PROJECT_KEY=your_mida_project_key
MIDA_API_KEY=your_mida_api_key
MIDA_API_BASE=https://api-us.mida.so
# Fallback only: if the reporting API isn't used, list Mida test NAMES to read
# via the GA4 bridge (comma-separated). Requires Mida's GA4 integration enabled
# and mida_test_name / mida_variant registered as GA4 custom dimensions.
MIDA_BRIDGE_TESTS=

# ---- Notion (Ledger / observability) ------------------------------------
# Internal integration token (https://www.notion.so/my-integrations).
# The integration must be shared on the "CRO — Conversion Intelligence Programme"
# parent page so it can read/write the three databases below.
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DB_HYPOTHESES=873a3600a88b47428934ef6f5cce3333
NOTION_DB_TESTS=b6118f3b0c774bffa81f17fdfb1fa8f5
NOTION_DB_RUNLOG=9c48b09cab984ae1b0fdeee5c55c2416

# ---- Programme config ---------------------------------------------------
# Owner label written to the "Owner agent" field on hypotheses.
CRO_OWNER=CRO
